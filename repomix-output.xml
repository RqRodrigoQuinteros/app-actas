  if (!dateStr) return '';
  // Si ya está en DD/MM/YYYY, devolverlo así
  if (dateStr.includes('/')) return dateStr;
  // Si está en YYYY-MM-DD, convertirlo
  const parts = dateStr.split('-');
  if (parts.length === 3) {
    return `${parts[2]}/${parts[1]}/${parts[0]}`;
