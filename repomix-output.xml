                )}
                {loadingTemplate && <p className="text-xs text-blue-500 mt-1">Cargando template...</p>}
              </div>

              <div className="mb-4" style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '12px' }}>
                <div>
                  <label className="label-field">Exp. Digital</label>
