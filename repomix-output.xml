        {{#if expediente}}<tr><td>N° Expediente</td><td>{{expediente}}</td></tr>{{/if}}
        <tr><td>Responsable</td><td>{{responsable_nombre}}</td></tr>
        <tr><td>DNI Responsable</td><td>{{responsable_dni}}</td></tr>
        <tr><td>Carácter</td><td>{{responsable_caracter}}</td></tr>
        <tr><td>Fecha</td><td>{{fecha}}</td></tr>
        <tr><td>Inspector/a</td><td>{{inspector_nombre}} — DNI {{inspector_dni}}</td></tr>
      </table>
    </div>
  </div>

  {{#if observaciones}}
  <div class="observaciones">
    <strong>Observaciones / Motivo de Notificación:</strong><br>
    <p class="justificado">{{observaciones}}</p>
  </div>
  {{/if}}

  <div class="emplazamiento">
    SE EMPLAZA POR EL TÉRMINO DE <strong>{{emplazamiento_valor}} {{emplazamiento_tipo}} Hábiles</strong>
    A CUMPLIMENTAR LAS OBSERVACIONES FORMULADAS BAJO APERCIBIMIENTO DE CLAUSURA,
    SUMARIO Y DENUNCIA PENAL SI CORRESPONDIERE, EN CASO DE INCUMPLIMIENTO.
  </div>

  <div class="firmas">
    <div class="bloque-firma">
      {{#if firma_inspector}}
        <img src="{{firma_inspector}}" class="firma-img" alt="Firma Inspector" />
      {{else}}
        <div style="height: 80px;"></div>
      {{/if}}
      <div class="linea-firma"></div>
      <p class="firma-label">Firma del Inspector</p>
      <p class="firma-datos">{{inspector_nombre}}</p>
      <p class="firma-datos">DNI: {{inspector_dni}}</p>
    </div>
    <div class="bloque-firma">
      {{#if firma_responsable}}
        <img src="{{firma_responsable}}" class="firma-img" alt="Firma Responsable" />
      {{else}}
        <div style="height: 80px;"></div>
      {{/if}}
      <div class="linea-firma"></div>
      <p class="firma-label">Firma del Responsable / Notificado</p>
      <p class="firma-datos">{{responsable_nombre}}</p>
      <p class="firma-datos">DNI: {{responsable_dni}}</p>
    </div>
  </div>

</body>
