<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: Arial, sans-serif; font-size: 10.5pt; line-height: 1.45; color: #000; }

    h1.titulo {
      text-align: center;
      text-decoration: underline;
      font-size: 13pt;
      font-weight: bold;
      margin: 10px 0 4px;
      text-transform: uppercase;
