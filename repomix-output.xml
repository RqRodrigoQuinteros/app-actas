                Siguiente →
              </button>
            </div>
          )}

          {/* PASO 2 — Propiedad y Director Técnico */}
          {paso === 2 && (
            <div>
              <h2 className="text-xl font-bold mb-4">Propiedad y Director Técnico</h2>

